# ── Build outputs ──────────────────────────────────────────────────────────────
dist
dist-ssr
*.local

# ── Dependencies ───────────────────────────────────────────────────────────────
node_modules

# ── Environment & secrets ──────────────────────────────────────────────────────
.env
.env.*
.env.local
.env.*.local
!.env.example

# ── Deployment configs (may contain tokens/keys) ───────────────────────────────
.vercel
.netlify
.firebase
firebase.json
.firebaserc

# ── IDE & AI tool folders ──────────────────────────────────────────────────────
# Cursor IDE workspace settings (local to your machine)
.cursor/
# Claude AI local settings & plugin data
.claude/
.agents/

# ── Logs ───────────────────────────────────────────────────────────────────────
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# ── OS artifacts ───────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
Desktop.ini

# ── Editor artifacts ───────────────────────────────────────────────────────────
.vscode/*
!.vscode/extensions.json
.idea
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# ── TypeScript build cache ─────────────────────────────────────────────────────
*.tsbuildinfo

# ── Python bytecode (from AI skill scripts) ────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class

# ── Test & coverage output ─────────────────────────────────────────────────────
coverage/
.nyc_output/
test-results/
playwright-report/
